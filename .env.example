# PostgreSQL connection string
# Docker Compose maps Postgres to host port 5433 (avoids conflict with local Postgres on 5432)
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/happyrobot

# API key for HappyRobot tool calls and dashboard
API_KEY=change-me-to-a-secure-random-string

# Optional: FMCSA QCMobile API web key (geo-locked; omit to use mock carriers only)
FMCSA_WEB_KEY=

# HappyRobot web call (server-only — never expose in NEXT_PUBLIC_*)
HAPPYROBOT_API_KEY=
HAPPYROBOT_WORKFLOW_ID=

# Broker pay bounds as fractions of list rate (cap counters only, not carrier accepts)
NEGOTIATION_FLOOR_RATIO=0.85
NEGOTIATION_CEILING_RATIO=1.10
